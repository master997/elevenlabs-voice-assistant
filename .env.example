# ElevenLabs
ELEVENLABS_API_KEY=your_api_key_here

# Base URL for agent tool calls.
# Local dev: run `ngrok http 8080` and paste the https URL here.
# Production: your Fly.io URL, e.g. https://sdr-briefing-api.fly.dev
API_BASE_URL=https://sdr-briefing-api.fly.dev

# Set by create_agent.py after agent is created — do not edit manually
ELEVENLABS_AGENT_ID=

